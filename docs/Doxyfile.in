# Doxyfile configuration for DTL

PROJECT_NAME           = "Distributed Template Library (DTL)"
PROJECT_NUMBER         = @DTL_VERSION_FULL@
PROJECT_BRIEF          = "C++20 header-only library for distributed computing"
PROJECT_LOGO           =

OUTPUT_DIRECTORY       = docs/_generated/doxygen
CREATE_SUBDIRS         = NO

INPUT                  = include/dtl
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.h
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */detail/*

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
GENERATE_MAN           = NO

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = DTL_HAS_MPI \
                         DTL_ENABLE_CUDA \
                         __cplusplus=202002L

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES

SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_GROUP_NAMES       = YES

SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = YES
SHOW_USED_FILES        = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = NO
